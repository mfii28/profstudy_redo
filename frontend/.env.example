# Profs Training Solutions — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ------------------------------------------------------------
# Firebase Client SDK (public — safe to expose to the browser)
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ------------------------------------------------------------
# Firebase Admin SDK (server-only — NEVER expose to the browser)
# ------------------------------------------------------------
FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Alternative to FIREBASE_ADMIN_CREDENTIALS (recommended for local Windows env files)
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_ADMIN_PRIVATE_KEY_ID=your_private_key_id
# FIREBASE_ADMIN_CLIENT_ID=your_client_id

# ------------------------------------------------------------
# Application base URL (used in emails, redirects, etc.)
# Development: http://localhost:5000  |  Production: https://yourdomain.com
# ------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:5000

# ------------------------------------------------------------
# Paystack (Ghana payment gateway — https://dashboard.paystack.com)
# ------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# ------------------------------------------------------------
# Resend (transactional email — https://resend.com/api-keys)
# ------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
APP_EMAIL_DOMAIN=mytestingdomain.icu
APP_EMAIL_FROM=no-reply@mytestingdomain.icu
INTERNAL_EMAIL_SECRET=replace_with_long_random_secret

# ------------------------------------------------------------
# Cloudflare R2 Storage (S3-compatible)
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=profstudymate
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=https://cdn.mytestingdomain.icu

# ------------------------------------------------------------
# Zoom Server-to-Server OAuth (for automatic meeting creation)
# Marketplace app type: Server-to-Server OAuth
# ------------------------------------------------------------
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_s2s_client_id
ZOOM_CLIENT_SECRET=your_zoom_s2s_client_secret

# Optional legacy values (manual Zoom links still supported in UI)
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret

# ------------------------------------------------------------
# Google AI / Genkit (Gemini 2.5 Flash — https://aistudio.google.com)
# Set either GOOGLE_API_KEY or GEMINI_API_KEY.
# ------------------------------------------------------------
GOOGLE_API_KEY=your_google_ai_api_key
# GEMINI_API_KEY=your_gemini_api_key

# Optional: Gemini model id for student AI tutor chat (default: gemini-2.5-flash).
# If you see model-not-found errors, try: gemini-2.0-flash
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Course RAG (Firestore vector search on courses/*/ragChunks.embedding, 768-dim text-embedding-004)
# RAG text+vectors live in Firestore — not in Cloudflare R2 (R2 is for uploaded files / media only).
# Deploy indexes: firebase deploy --only firestore:indexes
# Migrate legacy number[] embeddings to Firestore vectors: npm run migrate:rag-vector:dry then migrate:rag-vector:apply
# RAG_DISABLE_FIRESTORE_VECTOR=true

# ------------------------------------------------------------
# Upstash Redis (distributed rate limiting)
# https://console.upstash.com/ — create a Redis database and get REST URL/token
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ------------------------------------------------------------
# Sentry (error tracking — https://sentry.io)
# Set in production for error aggregation
# ------------------------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ------------------------------------------------------------
# Feature Flags (optional)
# ------------------------------------------------------------
# ENABLE_SCHEDULED_CLEANUP=true
# ENABLE_EMAIL_RETRY=true
# Admin route governance: "mvp" (default) or "full"
# ADMIN_ROUTE_MODE=full

# ------------------------------------------------------------
# Arkesel SMS / WhatsApp (env only — not stored in Firestore or admin UI)
# https://developers.arkesel.com
# ------------------------------------------------------------
ARKESEL_API_KEY=ark_xxxxxxxxxxxxxxxxxxxxxxxx
ARKESEL_SMS_API_KEY=ark_sms_xxxxxxxxxxxxxxxxxxxxxxxx
# Max 10 characters (less than 11) — must match your Arkesel-approved sender ID
ARKESEL_SMS_SENDER_ID=PROFS
ARKESEL_WHATSAPP_API_KEY=ark_wa_xxxxxxxxxxxxxxxxxxxxxxxx
ARKESEL_WHATSAPP_SENDER=2332XXXXXXXX

# Internal cron/queue runner auth (required for /api/internal/communications/process)
INTERNAL_JOBS_SECRET=replace_with_long_random_secret

# Optional: override default OTP email sender (falls back to APP_EMAIL_FROM)
# OTP_EMAIL_FROM=otp@mytestingdomain.icu
