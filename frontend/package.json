{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 5000",
    "dev:all": "next dev -H 0.0.0.0 -p 5000",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -H 127.0.0.1 -p 5000",
    "dev:turbo": "next dev --turbo -H 127.0.0.1 -p 5000",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 5000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:rules-sync": "node scripts/check-firestore-rules-sync.js",
    "migrate:assets:dry": "node scripts/migrate-lesson-library-keys.js",
    "migrate:assets:apply": "node scripts/migrate-lesson-library-keys.js --apply",
    "migrate:assets:fs:dry": "node scripts/migrate-lesson-library-keys.js --filesystem-only",
    "migrate:assets:fs:apply": "node scripts/migrate-lesson-library-keys.js --filesystem-only --apply",
    "migrate:rag-vector:dry": "node scripts/migrate-rag-chunks-to-firestore-vector.js",
    "migrate:rag-vector:apply": "node scripts/migrate-rag-chunks-to-firestore-vector.js --apply",
    "test": "vitest run",
    "test:watch": "vitest"
  },
